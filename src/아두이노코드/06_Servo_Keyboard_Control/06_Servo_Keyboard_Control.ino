// =======================================================
// 🎓 6교시: PWM 펄스의 이해와 서보모터(SG-90) 수동 제어
// =======================================================

/* 
 * 💡 [학생들을 위한 팁: 일반 서보(180) vs 무한회전 서보(360)]
 * 이번 로봇 팔 수업에서는 재밌게도 두 종류의 모터를 다룹니다!
 * 1) 일반 180도 서보 (Tilt 모터)
 *    - 각도를 주면, 정확히 그 각도로 이동해서 멈춥니다.
 * 2) 무한회전 360도 서보 (Pan 모터)
 *    - 이 모터는 바퀴처럼 뱅글뱅글 돕니다! 그래서 위치의 개념이 없고 오직 **속도와 방향**만 존재합니다!
 *    - 90을 주면 정지(Break) 상태가 됩니다.
 *    - 숫자가 90에서 멀어질수록(0에 가까워지거나 180에 가까워질수록) 초고속으로 회전합니다.
 */
 * 서보모터(SG-90)는 0도부터 180도 사이만 정확하게 찾아가는 모터입니다.
 * 이 모터는 전기를 "찌릿- 찌릿-" 하고 보내주는 시간에 따라 자기 위치를 찾아갑니다.
 * 이 현상을 **PWM(Pulse Width Modulation, 펄스 폭 변조)** 이라고 해요!
 * - 0도 : 전기를 1밀리초(0.001초)만 찌릿!
 * - 90도 : 전기를 1.5밀리초(0.0015초) 정직하게 찌릿!
 * - 180도 : 전기를 2밀리초(0.002초) 길게 찌릿!
 * 다행히 아두이노의 전용 라이브러리 <Servo.h>가 이 계산을 자동으로 다 해줍니다.
 */

#include <Servo.h>

// 모터 2개를 조종할 리모콘 변수를 만들어 줍니다.
Servo panServo;   // 좌우(Pan) 담당 모터 (나중에는 360도 스피드 모터로 진화합니다!)
Servo tiltServo;  // 상하(Tilt) 담당 모터

void setup() {
  Serial.begin(9600); // 파이썬과 9600 속도로 대화를 시작합니다.
  
  // 모터의 전원(신호선)을 연결할 핀 번호를 지정합니다!
  // 아두이노 보드에서 물결표(~)가 그려진 핀들이 바로 전기 신호(PWM)를 정밀하게 조절할 수 있는 핀들입니다.
  panServo.attach(9);   // 디지털 9번 핀
  tiltServo.attach(10); // 디지털 10번 핀
  
  // 수업이 시작될 때 카메라가 똑바로 앞을 쳐다보도록 둘 다 90도로 꽂아줍니다!
  panServo.write(90);
  tiltServo.write(90);
}

void loop() {
  // 파이썬에서 문자가 여러 개 뭉쳐서(예: P45T110\n) 날아왔는지 확인합니다.
  if (Serial.available() > 0) {
    // 문자열을 '\n'(엔터키)가 나올 때까지 통째로 주욱 읽어들입니다.
    String data = Serial.readStringUntil('\n'); 
    
    // 외계어 섞이지 않게 'P'와 'T'라는 글자가 도대체 몇 번째 칸에 적혀있는지 찾습니다.
    int pIndex = data.indexOf('P');
    int tIndex = data.indexOf('T');
    
    // 만약 데이터 안에 'P'와 'T'가 둘 다 정상적으로 잘 들어있다면? (해석 시작)
    if (pIndex != -1 && tIndex != -1) {
      
      // 글자들을 자를 가위(substring)를 씁니다.
      // P글자 뒤부터 T글자 전까지 싹둑 자르면 좌우 각도(Pan) 숫자만 딱 나옵니다.
      String panStr = data.substring(pIndex + 1, tIndex);
      
      // T글자 뒤부터 맨 끝까지 자르면 상하 각도(Tilt) 숫자만 나옵니다.
      String tiltStr = data.substring(tIndex + 1);
      
      // 글자(String)였던 "45"를 수학 계산이 가능한 진짜 숫자(Integer) 45로 변환시킵니다.
      int panAngle = panStr.toInt();
      int tiltAngle = tiltStr.toInt();
      
      // 혹시라도 파이썬 코드에서 안전장치가 고장나 190도 같은 값이 날아왔을 때를 대비한 '물리적 2차 안전장치'입니다.
      panAngle = constrain(panAngle, 0, 180);
      tiltAngle = constrain(tiltAngle, 0, 180);
      
      // 🚀 최종명령! 아두이노 핀으로 모터에 정밀한 PWM 전기를 쏘아줍니다! (이동)
      panServo.write(panAngle);
      tiltServo.write(tiltAngle);
    }
  }
}
