// =======================================================
// 🎓 1교시: 파이썬과 처음으로 인사하기! (시리얼 통신 기초)
// =======================================================

// 아두이노가 켜지면 딱 한 번 실행되는 준비 장소입니다.
void setup() {
  // 1. 파이썬(컴퓨터)과 대화를 주고받을 통신 속도(Baud Rate)를 9600으로 맞춥니다.
  Serial.begin(9600);
  
  // 2. 아두이노에 내장된 LED(보통 13번 핀)를 빛을 '내보내는' 출력 모드로 설정합니다.
  pinMode(LED_BUILTIN, OUTPUT);
  
  // 처음 시작할 때는 일단 불을 꺼둡니다.
  digitalWrite(LED_BUILTIN, LOW); 
}

// 전원이 켜져 있는 동안 무한히 반복해서 실행되는 곳입니다.
void loop() {
  // 3. 파이썬에서 전송한 데이터(문자)가 시리얼 버퍼에 도착했는지 확인합니다.
  if (Serial.available() > 0) {
    
    // 4. 도착한 데이터를 한 글자(char) 읽어와서 command라는 상자에 넣습니다.
    char command = Serial.read();
    
    // 5. 조건문(if)을 사용해 명령어가 무엇인지 검사합니다.
    if (command == '1') {
      digitalWrite(LED_BUILTIN, HIGH); // 불을 켭니다!
    } 
    else if (command == '0') {
      digitalWrite(LED_BUILTIN, LOW);  // 불을 끕니다!
    }
    
    // (선택) 만약 엔터키(\n) 등 다른 잡음 문자가 넘어온다면 무시하고 넘어갑니다.
  }
}
